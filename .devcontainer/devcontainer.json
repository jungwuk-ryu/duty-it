{
    "name": "Dutyit Flutter Dev",
    "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
    },
    "containerEnv": {
        "WAKATIME_API_KEY": "${localEnv:WAKATIME_API_KEY}",
        "FIREBASE_PROJECT_ID": "${localEnv:FIREBASE_PROJECT_ID}",
        "GOOGLE_APPLICATION_CREDENTIALS": "${localEnv:GOOGLE_APPLICATION_CREDENTIALS}"
    },
    "postCreateCommand": "/bin/bash .devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "dart-code.flutter",
                "dart-code.dart-code",
                "wakatime.vscode-wakatime"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "wakatime.apiKey": "${containerEnv:WAKATIME_API_KEY}"
            }
        }
    }
}